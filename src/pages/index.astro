---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Zachary Matus</div>
    <div class="text-3xl py-3 font-bold">a Devops Support Engineer</div>
    <div class="py-2">
      <text class="text-lg">
        Welcome to my portfolio.
      </text>
    </div>

    <section class="mt-8 mb-10">
      <div class="grid grid-cols-2 gap-3 md:flex md:flex-wrap">
        <a class="btn btn-primary w-full md:w-auto md:min-w-[10rem]" href="https://www.linkedin.com/in/zmatus/" target="_blank">Let's Connect</a>
        <a class="btn btn-outline w-full md:w-auto md:min-w-[10rem]" href="/resume">Resume</a>
        <a class="btn btn-outline w-full md:w-auto md:min-w-[10rem]" href="/projects">Projects</a>
        <a class="btn btn-outline w-full md:w-auto md:min-w-[10rem]" href="mailto:zachary.matus@gmail.com">Contact</a>
      </div>
    </section>
  </div>

  <section class="mb-10">
    <div class="text-2xl font-bold mb-4">Recent Project Highlights</div>
    <div class="grid gap-4">
      <a class="card bg-base-200 border border-base-300 hover:border-base-content/20 transition-colors" href="/projects#terraform-oci">
        <div class="card-body p-5">
          <div class="card-title text-lg">Terraform — OCI infrastructure</div>
          <p>Multi-region, auditable provisioning for regulated environments.</p>
        </div>
      </a>
      <a class="card bg-base-200 border border-base-300 hover:border-base-content/20 transition-colors" href="/projects#jenkins-ansible">
        <div class="card-body p-5">
          <div class="card-title text-lg">Jenkins + Ansible automation</div>
          <p>Automated multi-stage .NET deployments with approvals and rollback paths.</p>
        </div>
      </a>
      <a class="card bg-base-200 border border-base-300 hover:border-base-content/20 transition-colors" href="/projects#cerner-ci-cd">
        <div class="card-body p-5">
          <div class="card-title text-lg">Cerner CI/CD feature traceability</div>
          <p>Automated artifact-to-feature association for consistent release metadata.</p>
        </div>
      </a>
    </div>
  </section>

</BaseLayout>